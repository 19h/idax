def ask_address(prompt: str, default_value: int = ...) -> int: ...
def ask_long(prompt: str, default_value: int = ...) -> int: ...
def ask_text(prompt: str, default_value: str = ..., max_size: int = ...,
             accept_tabs: bool = ..., normal_font: bool = ...) -> str: ...
def ask_form(markup: str, *bindings: FormBinding) -> bool: ...
def copy_to_clipboard(text: str) -> None: ...
def read_clipboard() -> str: ...
def clipboard_backend() -> str: ...
def form_sval(value: int = ...) -> FormSvalBinding: ...
def form_int(value: int = ...) -> FormIntBinding: ...
def form_bitset(value: int = ...) -> FormU16Binding: ...
def form_radio(value: int = ...) -> FormU16Binding: ...
def form_address(value: int = ...) -> FormAddressBinding: ...
def form_text(value: str = ...) -> FormTextBinding: ...
def form_path(value: str = ..., for_saving: bool = ...) -> FormPathBinding: ...
def form_builder(title: str) -> FormBuilder: ...
def jump_to(address: int) -> None: ...
def screen_address() -> int: ...
def selection() -> Range: ...
def widget_type(widget: Widget | HostHandle) -> WidgetType: ...
def create_widget(title: str) -> Widget: ...
def create_custom_viewer(title: str, lines: list[str]) -> Widget: ...
def set_custom_viewer_lines(viewer: Widget, lines: list[str]) -> None: ...
def custom_viewer_line_count(viewer: Widget) -> int: ...
def custom_viewer_jump_to_line(viewer: Widget, line_index: int, x: int = ...,
                               y: int = ...) -> None: ...
def custom_viewer_current_line(viewer: Widget, mouse: bool = ...) -> str: ...
def refresh_custom_viewer(viewer: Widget) -> None: ...
def close_custom_viewer(viewer: Widget) -> None: ...
def show_widget(widget: Widget, options: ShowWidgetOptions = ...) -> None: ...
